<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
         Modern gear icon with six teeth.
         All content fits within the 66dp safe zone for adaptive icons.
    -->

    <!-- Gear tooth 1 — top (0°) -->
    <group android:rotation="0" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Gear tooth 2 (60°) -->
    <group android:rotation="60" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Gear tooth 3 (120°) -->
    <group android:rotation="120" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Gear tooth 4 — bottom (180°) -->
    <group android:rotation="180" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Gear tooth 5 (240°) -->
    <group android:rotation="240" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Gear tooth 6 (300°) -->
    <group android:rotation="300" android:pivotX="54" android:pivotY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M50,22 h8 c2,0 4,2 4,4 v6 c0,2 -2,4 -4,4 h-8 c-2,0 -4,-2 -4,-4 v-6 c0,-2 2,-4 4,-4 Z" />
    </group>

    <!-- Main gear hub with center cutout (donut using evenOdd fill) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M54,31 A23,23 0,1,1 54,77 A23,23 0,1,1 54,31 Z M54,44 A10,10 0,1,1 54,64 A10,10 0,1,1 54,44 Z" />

    <!--
        Center icon: stylized multi-tool mark
        - Play triangle (Media)
        - Page lines (Ebook)
        - Light rays (Light Meter)
    -->

    <!-- Play triangle (Media) — top -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M50.5,46.5 L50.5,52.5 L55.5,49.5 Z" />

    <!-- Page lines (Ebook) — right -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M56,48 h3.5 M56,50.5 h3.5 M56,53 h2" />

    <!-- Light burst (Light Meter) — bottom-left -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M48.5,56 m-1.8,0 a1.8,1.8 0,1,0 3.6,0 a1.8,1.8 0,1,0 -3.6,0" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:pathData="M48.5,50.5 v-1.5 M48.5,58 v1.5 M46,54.5 h-1.5 M51,54.5 h1.5" />

</vector>
